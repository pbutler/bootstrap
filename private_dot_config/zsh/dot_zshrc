_vactivate() {
  local venv pyver desc line cfg
  local -a venvs
  local active=${VIRTUAL_ENV:t}
  for venv in ~/.virtualenvs/*(N/:t); do
    pyver=unknown
    cfg=~/.virtualenvs/$venv/pyvenv.cfg
    if [[ -r $cfg ]]; then
      while IFS= read -r line; do
        if [[ $line == version\ *=* ]]; then
          pyver=${line#*= }
          break
        elif [[ $line == version_info\ *=* ]]; then
          pyver=${line#*= }
          break
        fi
      done < $cfg
    fi
    desc="Python $pyver"
    [[ $venv == $active ]] && desc+=" — active"
    venvs+=("$venv:$desc")
  done
  _describe 'virtualenv' venvs
}

compdef _vactivate vactivate vset

_vmake() {
  case $CURRENT in
    2)
      _message 'new virtualenv name'
      ;;
    3)
      local -A seen
      local f ver
      for f in ${^path}/python*(N*); do
        ver=${${f:t}#python}
        [[ $ver == <->(.<->)# ]] || continue
        [[ -z ${seen[$ver]} ]] && seen[$ver]=${f:h}
      done
      # Pythons managed by uv
      if (( $+commands[uv] )); then
        local -a fields
        local tag impl
        while read -rA fields; do
          tag=${fields[1]}
          [[ -z $tag ]] && continue
          # uv prints "<download available>" for non-installed versions
          [[ ${fields[2]:-} == \<* ]] && continue
          impl=${tag%%-*}
          ver=${tag#*-}
          ver=${ver%%-*}
          [[ $ver == <->(.<->)# ]] || continue
          [[ -z ${seen[$ver]} ]] && seen[$ver]="$impl (uv)"
        done < <(uv python list --only-installed 2>/dev/null)
      fi

      local -a versions
      for ver in ${(ko)seen}; do
        versions+=("$ver:${seen[$ver]}")
      done
      _describe 'python version' versions
      ;;
  esac
}

compdef _vmake vmake

